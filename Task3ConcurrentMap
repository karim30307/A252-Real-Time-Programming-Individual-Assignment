package Week11;

import java.util.concurrent.ConcurrentHashMap;
public class Task3ConcurrentMap {

    public static void main(String[] args) {

        System.out.println("           TASK 3: CONCURRENT MAP                 ");


        // 1. Using ConcurrentHashMap (Key: StudentID, Value: CourseCode)
        ConcurrentHashMap<String, String> studentCourseMap = new ConcurrentHashMap<>();

        // 2. Add at least 50 student-course records
        for (int i = 101; i <= 155; i++) {
            studentCourseMap.put("UUM" + i, "STIW3014");
        }
        // Variety items
        studentCourseMap.put("UUM201", "STIA1123");
        studentCourseMap.put("UUM202", "STID3024");

        // 3. Retrieve the course registered by a specific student
        String studentId = "UUM105";
        System.out.println("Course registered by " + studentId + ": " + studentCourseMap.get(studentId));

        // 4. Update the course of a student
        System.out.println("Updating UUM201 from STIA1123 to STIW3014...");
        studentCourseMap.replace("UUM201", "STIW3014");

        // 5. Check whether a student ID exists
        System.out.println("Does student ID 'UUM202' exist? " + studentCourseMap.containsKey("UUM202"));

        // 6. Remove a student registration
        System.out.println("Removing registration for 'UUM202'...");
        studentCourseMap.remove("UUM202");

        // 7. Display all registrations
        System.out.println("\n--- All Map Registrations ---");
        studentCourseMap.forEach((key, value) -> System.out.println("StudentID: " + key + " -> Course: " + value));
    }
}
